# OpenAI API Configuration
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o

# Directory Configuration
FRAMES_DIR=./stored-frames/sessions
GROUND_TRUTH_DIR=./ground-truth

# Processing Configuration
MAX_CONCURRENT_REQUESTS=5
IMAGE_RESIZE_WIDTH=512
IMAGE_DETAIL_LEVEL=high  # low, high, or auto
CONSISTENCY_CHECK_RUNS=3  # Run each image N times for validation (set to 1 to disable)
PROCESS_LIMIT=0  # 0 = all frames, or set a number for testing

# Cost Management
ENABLE_COST_TRACKING=true
MAX_COST_PER_SESSION=10.00  # Maximum cost in USD per session (safety limit)
